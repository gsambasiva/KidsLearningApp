# SmartKids Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smartkids
# For production: MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smartkids

# JWT
JWT_SECRET=MySuperSecret4321
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=hellosamba697@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=SmartKids Learning <noreply@smartkids.com>

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your_expo_access_token_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
